# ─────────────────────────────────────────────────────────────
# Production environment
# ─────────────────────────────────────────────────────────────

# Backend API — NGINX reverse-proxies /api to the backend,
# so we use a relative path (no CORS, no hardcoded host).
VITE_API_BASE_URL=/api

# App title
VITE_APP_TITLE=Smart Filter Hub

# Auto-dismiss duration for the data-source banner (ms)
VITE_BANNER_DURATION=4000
